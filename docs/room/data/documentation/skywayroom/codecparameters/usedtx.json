    {
      "content": [
        {
          "anchor": "discussion",
          "level": 2,
          "text": "Discussion",
          "type": "heading"
        },
        {
          "inlineContent": [
            {
              "text": "利用する場合、発話していない時の音声通信を停止します。",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "text": "コーデックでOpusが利用される場合は、デフォルトで利用します。",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "text": "利用しない場合は以下のように設定します。",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "code": [
            "let codec: Codec = .init(mimeType: \"audio/opus\")",
            "codec.parameters.useDTX = false",
            "// and publish with codec options"
          ],
          "syntax": null,
          "type": "codeListing"
        }
      ],
      "kind": "content"
    }
  ],
