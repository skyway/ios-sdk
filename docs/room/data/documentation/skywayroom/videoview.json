    {
      "content": [
        {
          "anchor": "overview",
          "level": 2,
          "text": "Overview",
          "type": "heading"
        },
        {
          "inlineContent": [
            {
              "text": "描画するためには",
              "type": "text"
            },
            {
              "code": "SKWLocalVideoStream",
              "type": "codeVoice"
            },
            {
              "text": "または",
              "type": "text"
            },
            {
              "code": "SKWRemoteVideoStream",
              "type": "codeVoice"
            },
            {
              "text": "の",
              "type": "text"
            },
            {
              "code": "attach(_:)",
              "type": "codeVoice"
            },
            {
              "text": "に引数を渡してください。",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "text": "StoryboardのCustom Classを利用する場合は",
              "type": "text"
            },
            {
              "code": "VideoView",
              "type": "codeVoice"
            },
            {
              "text": "ではなく",
              "type": "text"
            },
            {
              "code": "SKWVideoView",
              "type": "codeVoice"
            },
            {
              "text": "を指定して下さい。",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "text": "グラフィックスAPIはMetalを利用しています。",
              "type": "text"
            }
          ],
          "type": "paragraph"
        }
      ],
      "kind": "content"
    }
  ],
