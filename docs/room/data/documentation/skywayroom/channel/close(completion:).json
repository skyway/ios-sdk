          "name": "completion"
        }
      ]
    },
    {
      "content": [
        {
          "anchor": "discussion",
          "level": 2,
          "text": "Discussion",
          "type": "heading"
        },
        {
          "inlineContent": [
            {
              "code": "dispose(completion:)",
              "type": "codeVoice"
            },
            {
              "text": "とは異なり、Channelを閉じると参加しているMemberは全て退出し、Channelは破棄されます。",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "text": "入室している全てのMemberがPublishとSubscribeをしている場合は中止してから退出します。",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "text": "Close後のChannelインスタンスおよび、Channelで生成されたMember, Publication,",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "Subscriptionインスタンスは利用できません。",
              "type": "text"
            }
          ],
          "type": "paragraph"
        }
      ],
      "kind": "content"
    }
  ],
