    {
      "content": [
        {
          "anchor": "overview",
          "level": 2,
          "text": "Overview",
          "type": "heading"
        },
        {
          "inlineContent": [
            {
              "code": "CMSampleBuffer",
              "type": "codeVoice"
            },
            {
              "text": "の画像フレームをループ内からアップデートして描画を行います。",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "inlineContent": [
            {
              "text": "ReplayKitと組み合わせることでアプリの画面をソースにして画面共有が行えます。",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "code": [
            "let source: CustomFrameVideoSource = .init()",
            "RPScreenRecorder.shared().startCapture { buffer, _, err in",
            "    guard err == nil else {",
            "        return",
            "    }",
            "    source.updateFrame(with: buffer)",
            "} completionHandler: { _ in }",
            "",
            "let stream = source.createStream()"
          ],
          "syntax": "swift",
          "type": "codeListing"
        }
      ],
      "kind": "content"
    }
  ],
