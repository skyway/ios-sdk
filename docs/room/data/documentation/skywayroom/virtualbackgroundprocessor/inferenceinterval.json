          "anchor": "discussion",
          "level": 2,
          "text": "Discussion",
          "type": "heading"
        },
        {
          "inlineContent": [
            {
              "text": "CPU 使用率を抑えるため、このフレーム間隔ごとに 1 回だけセグメンテーションマスクを更新します。",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "値が大きいほど処理負荷が低下しますが、マスク更新の反応が遅くなります。",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "範囲: ",
              "type": "text"
            },
            {
              "code": "1...10",
              "type": "codeVoice"
            },
            {
              "text": "、デフォルト: ",
              "type": "text"
            },
            {
              "code": "2",
              "type": "codeVoice"
            },
            {
              "text": "。",
              "type": "text"
            }
          ],
          "type": "paragraph"
        }
      ],
      "kind": "content"
    }
